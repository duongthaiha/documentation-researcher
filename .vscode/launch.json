{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Doc Reviewer: Engineering",
      "type": "debugpy",
      "request": "launch",
      "module": "doc_reviewer.main",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        // "LANGFUSE_ENABLED": "true",
        // "LANGFUSE_BASE_URL": "http://172.17.0.1:3000",
        // "LANGFUSE_PUBLIC_KEY": "${env:LANGFUSE_PUBLIC_KEY}",
        // "LANGFUSE_SECRET_KEY": "${env:LANGFUSE_SECRET_KEY}",
        // "LANGFUSE_ENABLE_SENSITIVE_DATA": "false",
        // "LANGFUSE_DEBUG": "false"
        "GITHUB_MCP_TOKEN": "${env:GITHUB_MCP_TOKEN}"
      },
      "args": [
        "--file",
        "document/Microsoft Foundry adoption across my organization.md",
        "--industry",
        "engineering",
        "--rounds",
        "3"

      ],
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Doc Reviewer: Engineering (Hosted)",
      "type": "debugpy",
      "request": "launch",
      "module": "doc_reviewer.main",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        // "LANGFUSE_ENABLED": "true",
        // "LANGFUSE_BASE_URL": "http://172.17.0.1:3000",
        // "LANGFUSE_PUBLIC_KEY": "${env:LANGFUSE_PUBLIC_KEY}",
        // "LANGFUSE_SECRET_KEY": "${env:LANGFUSE_SECRET_KEY}",
        // "LANGFUSE_ENABLE_SENSITIVE_DATA": "false",
        // "LANGFUSE_DEBUG": "false"
        "GITHUB_MCP_TOKEN": "${env:GITHUB_MCP_TOKEN}"
      },
      "args": [
        "--file",
        "document/Microsoft Foundry adoption across my organization.md",
        "--industry",
        "engineering",
        "--rounds",
        "3",
        "--hosted"
      ],
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}
