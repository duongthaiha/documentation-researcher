# Azure AI Foundry project endpoint (required)
AZURE_AI_PROJECT_ENDPOINT=https://<project>.services.ai.azure.com/api/projects/<project-id>

# Model deployment name (required) — the default model for all agents.
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o

# Optional per-role model deployments. Spread agents across deployments so they
# don't all share one model's rate limit. Each falls back to
# AZURE_AI_MODEL_DEPLOYMENT_NAME when unset. Applied to the prompt agents at
# deploy time (re-run the deploy after changing these).
# CUSTOMER_MODEL_DEPLOYMENT_NAME=gpt-4.1-mini   # customers: high volume, simple
# RESEARCH_MODEL_DEPLOYMENT_NAME=gpt-4.1        # research: isolated (tool loops)
# WRITER_MODEL_DEPLOYMENT_NAME=gpt-5.4          # writer: best quality, 1 call

# WorkIQ MCP server URL (required)
WORKIQ_MCP_URL=http://localhost:8080/mcp

# GitHub MCP — personal access token for searching Microsoft official repos (optional)
# Falls back to `gh auth token` if not set and gh CLI is logged in.
# GITHUB_MCP_TOKEN=ghp_...

# Foundry connection IDs for authenticated MCP servers when running agents as
# HOSTED prompt agents (doc-reviewer --hosted). Foundry rejects inline MCP auth
# tokens/headers, so authenticated servers must reference a project connection.
# GITHUB_MCP_CONNECTION_ID=
# WORKIQ_MCP_CONNECTION_ID=

# Optional: number of Q&A rounds (default: 3)
# REVIEW_ROUNDS=3

# Optional: local Markdown research docs directory (default: ./research)
# RESEARCH_DIR=./research

# Optional: Langfuse observability (disabled by default)
# LANGFUSE_ENABLED=false
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# For a Langfuse Docker container running on your host machine from inside a devcontainer:
# LANGFUSE_BASE_URL=http://host.docker.internal:3000
# LANGFUSE_ENABLE_SENSITIVE_DATA=false
# LANGFUSE_DEBUG=false
